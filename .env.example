POSTGRES_USER=sentinal
POSTGRES_PASSWORD=changeme_please!
POSTGRES_DB=sentinal

# 32+ byte random string, e.g. `openssl rand -base64 48`
JWT_SECRET=change_me_this_is_a_secret_key_and_not_a_good_idea_to_use_this_in_production_seriously_change_me_but_if_you_do_it_at_least_will_work

# File storage: Local | AwsS3 | AzureBlob
FILE_STORAGE_PROVIDER=Local

# Required if FILE_STORAGE_PROVIDER=AzureBlob
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=

# Authentication settings
# Set to false to disable new user registration (existing users can still login)
AUTHENTICATION__ENABLEUSERREGISTRATION=true
